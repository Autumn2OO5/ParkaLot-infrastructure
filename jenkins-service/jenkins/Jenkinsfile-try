pipeline {
    agent any

    environment {
        IMAGE_NAME = 'parkalot-web-app'
        CONTAINER_NAME = 'web-app'
        APP_PORT = '3001'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    docker build -t ${IMAGE_NAME} .
                '''
            }
        }

        stage('Deploy Container') {
            steps {
                sh '''
                    if docker ps -q -f name=${CONTAINER_NAME}; then
                        docker stop ${CONTAINER_NAME}
                    fi
                    if docker ps -a -q -f name=${CONTAINER_NAME}; then
                        docker rm ${CONTAINER_NAME}
                    fi
                    docker run -d -p ${APP_PORT}:${APP_PORT} --name ${CONTAINER_NAME} ${IMAGE_NAME}
                '''
            }
        }
    }

    post {
        always {
            echo 'Pipeline finished.'
        }
        success {
            echo "Application deployed and available on port ${APP_PORT}."
        }
        failure {
            echo 'Build or deployment failed. Check the console output for details.'
        }
    }
}
